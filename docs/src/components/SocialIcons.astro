---
const links = [
	{
		label: 'GitHub',
		href: 'https://github.com/sarhatabaot/TradingCards',
		icon: 'github',
	},
	{
		label: 'Discord',
		href: 'https://discord.gg/4v9gsBCgg8',
		icon: 'discord',
	},
	{
		label: 'Jenkins',
		href: 'https://ci.codemc.io/job/sarhatabaot/job/TradingCards/',
		icon: 'jenkins',
	},
	{
		label: 'Modrinth',
		href: 'https://modrinth.com/plugin/tradingcards',
		icon: 'modrinth',
	},
];
---

{
	links.map(({ label, href, icon }) => (
		<a href={href} rel="me" class:list={['sl-flex', 'social-link', icon]}>
			<span class="sr-only">{label}</span>
			<span class:list={['icon', icon]} aria-hidden="true" />
		</a>
	))
}

<style>
	@layer starlight.core {
		.social-link {
			color: var(--sl-color-text-accent);
			padding: 0.5em;
			margin: -0.5em;
		}

		.social-link:hover {
			color: var(--sl-color-white);
		}

		.social-link.discord:hover {
			color: #5865f2;
		}

		.social-link.jenkins:hover {
			color: #d64636;
		}

		.social-link.modrinth:hover {
			color: #1bd96a;
		}

		.icon {
			display: block;
			width: 1.25rem;
			height: 1.25rem;
			background-color: currentColor;
			mask-repeat: no-repeat;
			mask-position: center;
			mask-size: contain;
			-webkit-mask-repeat: no-repeat;
			-webkit-mask-position: center;
			-webkit-mask-size: contain;
		}

